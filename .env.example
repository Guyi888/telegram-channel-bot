# ============================================================
# Telegram Channel Management Bot — Environment Variables
# ============================================================

# Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Super admin Telegram user IDs, comma-separated
SUPER_ADMIN_IDS=123456789,987654321

# Target publish channel (e.g. @mychannel or -100xxxxxxxxxx)
TARGET_CHANNEL_ID=@your_channel

# Admin review group ID (negative number, e.g. -100xxxxxxxxxx)
# Leave empty to send review to super admins' private chats instead
REVIEW_GROUP_ID=

# Database file path
DATABASE_PATH=data/bot.db

# ---- Pyrogram (Personal Account API for cross-channel collection) ----
# Get from https://my.telegram.org/apps
API_ID=
API_HASH=
PHONE_NUMBER=+1234567890
SESSION_NAME=collector_session

# ---- Webhook (optional, leave empty to use polling) ----
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_SECRET=
